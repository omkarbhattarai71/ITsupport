// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User model - supports both regular users and admins
model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  name          String
  role          String         @default("USER") // USER or ADMIN
  department    String?
  phone         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  requests      ItemRequest[]
  tickets       SupportTicket[]
  notifications Notification[]
  activityLogs  ActivityLog[]
}

// Inventory items available for request
model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String
  quantity    Int      @default(0)
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  requestItems RequestItem[]
}

// Item request from users
model ItemRequest {
  id          String        @id @default(cuid())
  userId      String
  status      String        @default("PENDING") // PENDING, APPROVED, DECLINED, READY, COLLECTED, RETURNED
  notes       String?
  adminNotes  String?
  priority    String        @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  approvedAt  DateTime?
  collectedAt DateTime?
  returnedAt  DateTime?
  approvedBy  String?
  
  user        User          @relation(fields: [userId], references: [id])
  items       RequestItem[]
}

// Many-to-many relationship between requests and inventory items
model RequestItem {
  id              String        @id @default(cuid())
  requestId       String
  inventoryItemId String
  quantity        Int           @default(1)
  
  request         ItemRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  
  @@unique([requestId, inventoryItemId])
}

// Support tickets for generic IT help
model SupportTicket {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  description String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, WAITING_INFO, RESOLVED, CLOSED
  priority    String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  resolution  String?
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resolvedAt  DateTime?
  
  user        User     @relation(fields: [userId], references: [id])
}

// Notifications for users
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // REQUEST_RECEIVED, REQUEST_APPROVED, REQUEST_DECLINED, READY_TO_COLLECT, TICKET_UPDATE, INFO_REQUIRED
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
}

// Activity logs for auditing
model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // CREATE, UPDATE, DELETE, APPROVE, DECLINE, COLLECT, RETURN
  entityType String   // USER, INVENTORY, REQUEST, TICKET
  entityId   String
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  
  user       User?    @relation(fields: [userId], references: [id])
}
